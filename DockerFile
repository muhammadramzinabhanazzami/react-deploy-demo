# ==========================================
# Tahap 1: Build Aplikasi (Node.js)
# ==========================================
FROM node:18-alpine AS builder
WORKDIR /app

# Salin package file dan instal dependencies
COPY package*.json ./
RUN npm install

# Salin seluruh source code dan lakukan build produksi
COPY . .
RUN npm run build

# ==========================================
# Tahap 2: Serve Hasil Build dengan Nginx
# ==========================================
FROM nginx:alpine

# Salin hasil build dari Tahap 1 ke folder HTML Nginx
COPY --from=builder /app/build /usr/share/nginx/html

# Buka port 80 untuk akses web
EXPOSE 80

# Jalankan Nginx server
CMD ["nginx", "-g", "daemon off;"]